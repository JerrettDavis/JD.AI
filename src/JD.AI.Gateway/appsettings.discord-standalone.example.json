{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://127.0.0.1:15795"
      }
    }
  },
  "Gateway": {
    "Server": { "Port": 15795, "Host": "127.0.0.1", "Verbose": true },
    "Auth": { "Enabled": false },
    "RateLimit": { "Enabled": true, "MaxRequestsPerMinute": 120 },
    "Providers": [
      { "Name": "openai-codex", "Enabled": true },
      { "Name": "copilot", "Enabled": true },
      { "Name": "ollama", "Enabled": true }
    ],
    "Agents": [
      {
        "Id": "support-agent",
        "Provider": "openai-codex",
        "Model": "gpt-5.3-codex",
        "SystemPrompt": "You are JD.AI Support. Be concise and operationally precise.",
        "AutoSpawn": true
      },
      {
        "Id": "lab-agent",
        "Provider": "openai-codex",
        "Model": "gpt-5.3-codex",
        "SystemPrompt": "You are JD.AI Lab. You help with prototypes and experiments.",
        "AutoSpawn": true
      }
    ],
    "Channels": [
      {
        "Type": "discord",
        "Name": "support-discord",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": { "BotToken": "env:DISCORD_BOT_TOKEN_SUPPORT" }
      },
      {
        "Type": "discord",
        "Name": "lab-discord",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": { "BotToken": "env:DISCORD_BOT_TOKEN_LAB" }
      }
    ],
    "Routing": {
      "DefaultAgentId": "support-agent",
      "Rules": [
        { "ChannelType": "discord", "ChannelName": "support-discord", "AgentId": "support-agent" },
        { "ChannelType": "discord", "ChannelName": "lab-discord", "AgentId": "lab-agent" }
      ]
    },
    "OpenClaw": {
      "Enabled": false,
      "AutoConnect": false
    }
  }
}
