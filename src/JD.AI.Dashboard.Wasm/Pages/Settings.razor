@page "/settings"
@inject GatewayApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Settings — JD.AI</PageTitle>

<div class="jd-page-header">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Settings</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" Size="Size.Small" data-testid="refresh-button" />
    </MudStack>
</div>

@if (_loading)
{
    <MudPaper Elevation="0" Class="pa-4">
        <MudSkeleton Width="400px" Height="40px" Class="mb-4" />
        <MudSkeleton Width="100%" Height="200px" Class="mb-3" />
        <MudSkeleton Width="100%" Height="200px" />
    </MudPaper>
}
else if (_config is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" data-testid="settings-error">
        Unable to load gateway configuration. Is the gateway running?
    </MudAlert>
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Class="jd-settings-tabs" data-testid="settings-tabs">
        <MudTabPanel Text="Server" Icon="@Icons.Material.Filled.Dns" ToolTip="Network, auth, and rate-limit settings">
            <SettingsServerTab Config="_config.Server" Auth="_config.Auth" RateLimit="_config.RateLimit" Api="Api" />
        </MudTabPanel>
        <MudTabPanel Text="Providers" Icon="@Icons.Material.Filled.Hub" ToolTip="AI model provider configuration">
            <SettingsProvidersTab Providers="_config.Providers" Api="Api" />
        </MudTabPanel>
        <MudTabPanel Text="Agents" Icon="@Icons.Material.Filled.SmartToy" ToolTip="Agent definitions and auto-spawn settings">
            <SettingsAgentsTab Agents="_config.Agents" AvailableProviders="_config.Providers" DefaultAgentId="_config.Routing.DefaultAgentId" Api="Api" />
        </MudTabPanel>
        <MudTabPanel Text="Channels" Icon="@Icons.Material.Filled.Cable" ToolTip="Messaging channel connections">
            <SettingsChannelsTab Channels="_config.Channels" Api="Api" />
        </MudTabPanel>
        <MudTabPanel Text="Routing" Icon="@Icons.Material.Filled.AltRoute" ToolTip="Channel-to-agent routing rules">
            <SettingsRoutingTab Routing="_config.Routing" AvailableAgents="_config.Agents" AvailableChannels="_config.Channels" Api="Api" />
        </MudTabPanel>
        <MudTabPanel Text="OpenClaw" Icon="@Icons.Material.Filled.Cloud" ToolTip="OpenClaw bridge integration">
            <SettingsOpenClawTab OpenClaw="_config.OpenClaw" Api="Api" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    private GatewayConfigModel? _config;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try { _config = await Api.GetConfigAsync(); }
        catch { _config = null; }
        _loading = false;
    }
}
