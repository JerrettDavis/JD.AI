@page "/routing"
@inject GatewayApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Routing — JD.AI</PageTitle>

<div class="jd-page-header">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText data-testid="page-title" Typo="Typo.h4">Channel → Agent Routing</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Sync" OnClick="SyncAsync" data-testid="sync-openclaw-button">Sync OpenClaw</MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" Size="Size.Small" data-testid="refresh-button" />
        </MudStack>
    </MudStack>
</div>

@if (_loading)
{
    <MudPaper Elevation="0">
        @for (var i = 0; i < 4; i++)
        {
            <div class="jd-skeleton-row">
                <MudSkeleton Width="24px" Height="24px" />
                <MudSkeleton Width="100px" Height="14px" />
                <MudSkeleton Width="200px" Height="14px" />
                <MudSpacer />
                <MudSkeleton Width="72px" Height="24px" />
            </div>
        }
    </MudPaper>
}
else if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" data-testid="routing-load-error">
        Failed to load routing mappings: @_loadError
    </MudAlert>
}
else
{
    <MudPaper Elevation="0">
        <MudDataGrid Items="@_mappings" Dense="true" Hover="true" EditMode="DataGridEditMode.Cell"
                     CommittedItemChanges="@(async (RoutingMapping m) => await OnMappingChanged(m))"
                     data-testid="routing-grid">
            <Columns>
                <PropertyColumn Property="x => x.ChannelType" Title="Channel" Editable="false">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" data-testid="routing-channel">
                            <MudIcon Icon="@GetChannelIcon(context.Item.ChannelType)" Size="Size.Small" />
                            <MudText>@context.Item.ChannelType</MudText>
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.AgentId" Title="Agent ID" Editable="true" />
                <TemplateColumn Title="Status" CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@(string.IsNullOrEmpty(context.Item.AgentId) ? Color.Default : Color.Primary)"
                                 data-testid="routing-status">
                            @(string.IsNullOrEmpty(context.Item.AgentId) ? "Default" : "Override")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mt-4" Elevation="0" data-testid="routing-diagram">
        <MudText Typo="Typo.h6" Class="mb-3">Routing Diagram</MudText>
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @if (_mappings is not null)
            {
                @foreach (var mapping in _mappings)
                {
                    <MudTimelineItem Color="@(string.IsNullOrEmpty(mapping.AgentId) ? Color.Default : Color.Primary)"
                                     Size="Size.Small">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@mapping.ChannelType</MudChip>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Secondary" />
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                                @(string.IsNullOrEmpty(mapping.AgentId) ? "OpenClaw Default" : mapping.AgentId)
                            </MudChip>
                        </MudStack>
                    </MudTimelineItem>
                }
            }
        </MudTimeline>
    </MudPaper>
}

@code {
    private RoutingMapping[]? _mappings;
    private bool _loading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            _mappings = await Api.GetRoutingMappingsAsync();
        }
        catch (Exception ex)
        {
            _mappings = [];
            _loadError = ex.Message;
            Snackbar.Add($"Failed to load routing mappings: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private async Task OnMappingChanged(RoutingMapping mapping)
    {
        try
        {
            await Api.MapRoutingAsync(mapping.ChannelType, mapping.AgentId);
            Snackbar.Add($"Routing updated: {mapping.ChannelType} → {mapping.AgentId}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
            await LoadAsync();
        }
    }

    private async Task SyncAsync()
    {
        try
        {
            await Api.SyncOpenClawAsync();
            Snackbar.Add("OpenClaw sync complete", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error); }
    }

    private static string GetChannelIcon(string type) => type.ToLowerInvariant() switch
    {
        "discord" => Icons.Material.Filled.Forum,
        "signal" => Icons.Material.Filled.Security,
        "slack" => Icons.Material.Filled.Tag,
        "telegram" => Icons.Material.Filled.Send,
        "web" => Icons.Material.Filled.Language,
        _ => Icons.Material.Filled.Cable
    };
}
