@inject GatewayApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText>
                Revoke API key <strong>@Key.Name</strong>?
            </MudText>
            <MudText Color="Color.Error" Typo="Typo.body2">
                This action cannot be undone. Any systems using this key will immediately lose access.
            </MudText>
            <MudTextField @bind-Value="_confirmName" Label="Type key name to confirm"
                         Placeholder="@Key.Name"
                         data-testid="revoke-key-confirm" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" data-testid="revoke-key-cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Submit"
                   Disabled="@(!IsConfirmed || _submitting)" data-testid="revoke-key-submit">
            @if (_submitting)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
            }
            Revoke
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public ApiKeyDisplayModel Key { get; set; } = null!;
    [Parameter] public EventCallback<string> OnRevoked { get; set; }
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private string _confirmName = "";
    private bool _submitting;

    private bool IsConfirmed => _confirmName == Key.Name;

    private async Task Submit()
    {
        if (!IsConfirmed) return;

        _submitting = true;
        try
        {
            await Api.RevokeApiKeyAsync(Key.Key);
            await OnRevoked.InvokeAsync(Key.Name);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to revoke key: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
