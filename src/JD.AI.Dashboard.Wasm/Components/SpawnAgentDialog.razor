@inject ISnackbar Snackbar

<MudDialog data-testid="spawn-agent-dialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Add" />
            <MudText>Spawn New Agent</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField data-testid="agent-provider-input" @bind-Value="_definition.Provider" Label="Provider" Variant="Variant.Outlined"
                          HelperText="e.g. ollama, claude-code, copilot" />
            <MudTextField data-testid="agent-model-input" @bind-Value="_definition.Model" Label="Model" Variant="Variant.Outlined"
                           HelperText="e.g. ollama/qwen3:30b-instruct" />
            <MudTextField data-testid="agent-systemprompt-input" @bind-Value="_definition.SystemPrompt" Label="System Prompt" Variant="Variant.Outlined"
                           Lines="4" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton data-testid="confirm-spawn-button" Color="Color.Primary" Variant="Variant.Filled" OnClick="SpawnAsync" Disabled="_spawning">
            @if (_spawning) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Spawn
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public GatewayApiClient Api { get; set; } = null!;

    private AgentDefinition _definition = new();
    private bool _spawning;

    private void Cancel() => MudDialog.Cancel();

    private async Task SpawnAsync()
    {
        if (string.IsNullOrWhiteSpace(_definition.Provider) || string.IsNullOrWhiteSpace(_definition.Model))
            return;

        _spawning = true;
        try
        {
            var createdId = await Api.SpawnAgentAsync(_definition);
            Snackbar.Add($"Agent '{createdId}' spawned", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally { _spawning = false; }
    }
}
