namespace JD.AI.Dashboard.Wasm.Models;

/// <summary>Represents an API key for display in the dashboard (values are masked).</summary>
public sealed class ApiKeyDisplayModel
{
    public required string Key { get; init; }
    public required string Name { get; init; }
    public required string Role { get; init; }
    public required DateTimeOffset CreatedAt { get; init; }
    public DateTimeOffset? ExpiresAt { get; init; }
    public required bool IsRevoked { get; init; }
    public DateTimeOffset? RevokedAt { get; init; }
    public DateTimeOffset? LastUsedAt { get; init; }
    public long UsageCount { get; init; }
    public string? PreviousKey { get; init; }
}

/// <summary>Request to create a new API key.</summary>
public sealed class CreateApiKeyRequest
{
    public required string Name { get; init; }
    public string? Description { get; init; }
    public string Role { get; init; } = "User";
    public int? ExpiryDays { get; init; }
}

/// <summary>Response after creating an API key (contains the full key).</summary>
public sealed class CreateApiKeyResponse
{
    public required string Key { get; init; }
    public required string Name { get; init; }
    public required string Role { get; init; }
    public required DateTimeOffset CreatedAt { get; init; }
    public DateTimeOffset? ExpiresAt { get; init; }
}

/// <summary>Response after rotating an API key.</summary>
public sealed class RotateApiKeyResponse
{
    public required string NewKey { get; init; }
    public required string OldKey { get; init; }
    public required DateTimeOffset RotatedAt { get; init; }
}
