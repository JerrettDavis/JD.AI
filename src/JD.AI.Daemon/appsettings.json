{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:15790"
      }
    }
  },
  "Gateway": {
    "Server": {
      "Port": 15790,
      "Verbose": false
    },
    "Auth": {
      "Enabled": false
    },
    "RateLimit": {
      "Enabled": true,
      "MaxRequestsPerMinute": 60
    },
    "Agents": [
      {
        "Id": "default",
        "Provider": "Ollama",
        "Model": "llama3.2-vision:latest",
        "SystemPrompt": "You are JD.AI running in daemon mode with real tool access. When asked to use a tool (web search, shell/exec, file read/write), you MUST either: (1) invoke the relevant tool and return its result, or (2) return a concrete execution failure with exact error text and tool name. Do NOT claim generic inability to access CLI/filesystem/tools in daemon mode. If a tool is blocked, report the specific blocker (permission, provider/tool-calling format, model capability, or dispatch error).",
        "AutoSpawn": true,
        "FallbackProviders": [
          "ollama/qwen3.5:27b",
          "copilot/gpt-4o",
          "claude-code"
        ]
      }
    ],
    "Channels": [
      {
        "Type": "web",
        "Name": "Web Chat",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": {}
      },
      {
        "Type": "discord",
        "Name": "Discord Bot",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": {
          "BotToken": "env:DISCORD_BOT_TOKEN",
          "EnableReactions": "true",
          "RequireMention": "true",
          "MentionRoleIds": "1485144772275601461"
        }
      },
      {
        "Type": "slack",
        "Name": "Slack Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": {
          "BotToken": "env:SLACK_BOT_TOKEN",
          "AppToken": "env:SLACK_APP_TOKEN"
        }
      },
      {
        "Type": "telegram",
        "Name": "Telegram Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": {
          "BotToken": "env:TELEGRAM_BOT_TOKEN"
        }
      },
      {
        "Type": "signal",
        "Name": "Signal Bridge",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": {
          "Account": "env:SIGNAL_ACCOUNT"
        }
      }
    ],
    "Routing": {
      "DefaultAgentId": "default",
      "Rules": [
        {
          "ChannelType": "web",
          "AgentId": "default"
        },
        {
          "ChannelType": "discord",
          "AgentId": "default"
        },
        {
          "ChannelType": "slack",
          "AgentId": "default"
        },
        {
          "ChannelType": "telegram",
          "AgentId": "default"
        },
        {
          "ChannelType": "signal",
          "AgentId": "default"
        }
      ]
    },
    "OpenClaw": {
      "Enabled": false
    },
    "Providers": [
      {
        "Name": "ollama",
        "Enabled": true
      },
      {
        "Name": "claude-code",
        "Enabled": true
      },
      {
        "Name": "copilot",
        "Enabled": true
      },
      {
        "Name": "OpenAI Codex",
        "Enabled": true
      }
    ]
  }
}