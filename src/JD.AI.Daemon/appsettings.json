{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:15790"
      }
    }
  },
  "Gateway": {
    "Server": { "Port": 15790, "Verbose": false },
    "Auth": { "Enabled": false },
    "RateLimit": { "Enabled": true, "MaxRequestsPerMinute": 60 },

    "Agents": [
      {
        "Id": "default",
        "Provider": "OpenAI Codex",
        "Model": "gpt-5.1-codex-mini",
        "SystemPrompt": "You are JD.AI, a helpful AI assistant. You have access to tools including file operations, shell commands, web search, and code execution. Use these tools proactively to help users accomplish their goals.",
        "AutoSpawn": true,
        "FallbackProviders": [ "claude-code", "ollama/qwen3.5:27b" ]
      }
    ],

    "Channels": [
      {
        "Type": "web",
        "Name": "Web Chat",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": {}
      },
      {
        "Type": "discord",
        "Name": "Discord Bot",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": { "BotToken": "env:DISCORD_BOT_TOKEN" }
      },
      {
        "Type": "slack",
        "Name": "Slack Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "BotToken": "env:SLACK_BOT_TOKEN", "AppToken": "env:SLACK_APP_TOKEN" }
      },
      {
        "Type": "telegram",
        "Name": "Telegram Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "BotToken": "env:TELEGRAM_BOT_TOKEN" }
      },
      {
        "Type": "signal",
        "Name": "Signal Bridge",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "Account": "env:SIGNAL_ACCOUNT" }
      }
    ],

    "Routing": {
      "DefaultAgentId": "default",
      "Rules": [
        { "ChannelType": "web", "AgentId": "default" },
        { "ChannelType": "discord", "AgentId": "default" },
        { "ChannelType": "slack", "AgentId": "default" },
        { "ChannelType": "telegram", "AgentId": "default" },
        { "ChannelType": "signal", "AgentId": "default" }
      ]
    },

    "OpenClaw": {
      "Enabled": false
    },

    "Providers": [
      { "Name": "ollama", "Enabled": true },
      { "Name": "claude-code", "Enabled": true },
      { "Name": "copilot", "Enabled": true },
      { "Name": "OpenAI Codex", "Enabled": true }
    ]
  }
}
