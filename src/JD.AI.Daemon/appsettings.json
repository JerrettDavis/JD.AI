{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "JD.AI.Channels.OpenClaw": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:15790"
      }
    }
  },
  "Gateway": {
    "Server": { "Port": 15790, "Verbose": false },
    "Auth": { "Enabled": false },
    "RateLimit": { "Enabled": true, "MaxRequestsPerMinute": 60 },

    "Agents": [
      {
        "Id": "default",
        "Provider": "copilot",
        "Model": "claude-sonnet-4-6",
        "SystemPrompt": "You are a helpful AI assistant connected to the JD.AI gateway.",
        "AutoSpawn": true,
        "FallbackProviders": [ "claude-code", "ollama/qwen3.5:27b" ]
      }
    ],

    "Channels": [
      {
        "Type": "web",
        "Name": "Web Chat",
        "Enabled": true,
        "AutoConnect": true,
        "Settings": {}
      },
      {
        "Type": "discord",
        "Name": "Discord Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "BotToken": "env:DISCORD_BOT_TOKEN" }
      },
      {
        "Type": "slack",
        "Name": "Slack Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "BotToken": "env:SLACK_BOT_TOKEN", "AppToken": "env:SLACK_APP_TOKEN" }
      },
      {
        "Type": "telegram",
        "Name": "Telegram Bot",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "BotToken": "env:TELEGRAM_BOT_TOKEN" }
      },
      {
        "Type": "signal",
        "Name": "Signal Bridge",
        "Enabled": false,
        "AutoConnect": false,
        "Settings": { "Account": "env:SIGNAL_ACCOUNT" }
      }
    ],

    "Routing": {
      "DefaultAgentId": "default",
      "Rules": [
        { "ChannelType": "web", "AgentId": "default" },
        { "ChannelType": "discord", "AgentId": "default" },
        { "ChannelType": "slack", "AgentId": "default" },
        { "ChannelType": "telegram", "AgentId": "default" },
        { "ChannelType": "signal", "AgentId": "default" }
      ]
    },

    "OpenClaw": {
      "Enabled": true,
      "WebSocketUrl": "ws://127.0.0.1:18789/ws/gateway",
      "AutoConnect": true,
      "DefaultMode": "Passthrough",
      "Channels": {
        "discord": {
          "Mode": "Sidecar",
          "CommandPrefix": "/jdai"
        },
        "signal": {
          "Mode": "Intercept"
        }
      },
      "RegisterAgents": [
        {
          "Id": "jdai-default",
          "Name": "JD.AI Assistant",
          "Emoji": "🤖",
          "Theme": "Helpful .NET AI assistant powered by Semantic Kernel",
          "Model": "copilot/claude-sonnet-4-6",
          "GatewayAgentId": "default",
          "Bindings": [
            { "Channel": "discord" },
            { "Channel": "signal" }
          ]
        }
      ]
    },

    "Providers": [
      { "Name": "ollama", "Enabled": true },
      { "Name": "claude-code", "Enabled": true },
      { "Name": "copilot", "Enabled": true }
    ]
  }
}
