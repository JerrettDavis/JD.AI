{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "jb-cleanup",
      "group": "pre-commit",
      "command": "bash",
      "args": [".husky/scripts/jb-cleanup.sh", "${staged}"],
      "include": ["**/*.cs"],
      "output": "verbose",
      "windows": {
        "command": "bash",
        "args": [".husky/scripts/jb-cleanup.sh", "${staged}"]
      }
    },
    {
      "name": "dotnet-format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "JD.AI.slnx",
        "--severity",
        "warn",
        "--include",
        "${staged}"
      ],
      "include": ["**/*.cs"]
    },
    {
      "name": "restage-fixed-files",
      "group": "pre-commit",
      "command": "git",
      "args": ["add", "${staged}"],
      "include": ["**/*.cs"]
    },
    {
      "name": "dotnet-build",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "build",
        "JD.AI.slnx",
        "--configuration",
        "Release",
        "--no-restore"
      ],
      "include": ["**/*.cs", "**/*.csproj", "**/*.props", "**/*.targets"]
    },
    {
      "name": "smart-test",
      "group": "pre-commit",
      "command": "bash",
      "args": [".husky/scripts/smart-test.sh"],
      "include": ["**/*.cs", "**/*.csproj", "**/*.props", "**/*.targets"],
      "windows": {
        "command": "bash",
        "args": [".husky/scripts/smart-test.sh"]
      }
    }
  ]
}
