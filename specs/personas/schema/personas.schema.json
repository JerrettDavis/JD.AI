{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jd.ai/schemas/upss/personas.schema.json",
  "title": "JD.AI Persona Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "id",
    "version",
    "status",
    "metadata",
    "actorType",
    "roleName",
    "description",
    "permissions",
    "trustBoundaries",
    "responsibilities",
    "trace"
  ],
  "properties": {
    "apiVersion": { "type": "string", "const": "jdai.upss/v1" },
    "kind": { "type": "string", "const": "Persona" },
    "id": {
      "type": "string",
      "pattern": "^persona\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "version": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "retired"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owners", "reviewers", "lastReviewed", "changeReason"],
      "properties": {
        "owners": { "type": "array", "items": { "type": "string" } },
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "lastReviewed": { "type": "string" },
        "changeReason": { "type": "string" }
      }
    },
    "actorType": {
      "type": "string",
      "enum": ["user", "administrator", "external_system", "automated_agent"]
    },
    "roleName": { "type": "string" },
    "description": { "type": "string" },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "denied"],
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "denied": { "type": "array", "items": { "type": "string" } }
      }
    },
    "trustBoundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["boundary", "accessLevel", "justification"],
        "properties": {
          "boundary": { "type": "string" },
          "accessLevel": {
            "type": "string",
            "enum": ["standard", "elevated", "restricted", "read_only"]
          },
          "justification": { "type": "string" }
        }
      }
    },
    "responsibilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upstream", "downstream"],
      "properties": {
        "upstream": {
          "type": "array",
          "items": { "type": "string" }
        },
        "downstream": {
          "type": "object",
          "additionalProperties": false,
          "required": ["capabilities", "policies", "security", "useCases"],
          "properties": {
            "capabilities": { "type": "array", "items": { "type": "string" } },
            "policies": { "type": "array", "items": { "type": "string" } },
            "security": { "type": "array", "items": { "type": "string" } },
            "useCases": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
